NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/request_approval
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example@example.com
SMTP_PASS=replace-me
MAIL_FROM="Request Approval System <no-reply@approval-system.local>"

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
